generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid()) @db.Uuid()
  name     String
  email    String  @unique
  password String
  Asset    Asset[]
  order    Order[]
}

model Asset {
  id       Int    @id @default(autoincrement())
  symbol   Symbol
  balance  Int
  decimals Int    @default(2)
  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, symbol], name: "user_symbol_unique")
}

model Order {
  id           String       @id @default(uuid()) @db.Uuid
  userId       String       @db.Uuid
  side         Side
  pnl          Int
  decimals     Int          @default(4)
  openingPrice Int
  closingPrice Int
  status       OrderStatus
  qty          Int
  qtyDecimals  Int          @default(2)
  leverage     Int          @default(1)
  takeProfit   Int?
  stopLoss     Int?
  margin       Int
  closeReason  CloseReason?
  createdAt    DateTime     @default(now())
  closedAt     DateTime?
  User         User         @relation(fields: [userId], references: [id])
}

enum Symbol {
  USDT
  BTC
}

enum Side {
  long
  short
}

enum OrderStatus {
  open
  closed
}

enum CloseReason {
  takeProfit
  StopLoass
  Manual
  Liquidation
}
